  <string name="bd_enhanced_keymap_dialog_title">Kezish rejimini ishlatish uchun yaxshilangan terilmaga almashing</string>
  <string name="bd_enhanced_keymap_dialog_message">Kezish rejimini ishlatish uchun birlamchi terilmadan yaxshilangan terilmaga almashishi kerak. Bunda ayrim brayl yozuvidagi displey buyruqlari yangilanadi</string>
  <string name="bd_enhanced_keymap_dialog_positive_button">Sozlamalar</string>
  <string name="bd_command_change_dialog_title">Ayrim buyruqlar yangilandi</string>
  <string name="bd_command_change_dialog_message">Bu Brayl ekrani buyruqlari TalkBack ilovasining ushbu versiyasida yangilangan:\n\n• Avvalgi element: 1, 7 nuqtalarni bosing\n\n• Keyingi element: 4, 8 nuqtalarni bosing\n\n• Avvalgi oʻqish boshqaruvi: 2, 3, 7, 8 nuqtalarni bosing\n\n• Keyingi oʻqish boshqaruvi: 5, 6, 7, 8 nuqtalarni bosing</string>
  <string name="bd_preference_braille_contracted">Qisqartirilgan brayl</string>
  <string name="bd_preference_braille_uncontracted">Qisqartirilmagan brayl</string>
  <string name="bd_braille_grade_tips">Brayl ekrani yordamida qisqartirilgan va qisqartirilmagan orasida tezkor almashtirish uchun boʻsh joy va 1, 2, 4, 5 nuqtalarini bosing.\n\nAgar ikkala brayl darajasiga ega tildan foydalansangiz, bu buyruq ishlaydi.</string>
