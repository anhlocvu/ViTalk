  <string name="bd_turn_off_bd_confirm_dialog_title">Brayl ekrani sozlamasi oʻchirilsinmi?</string>
  <string name="bd_turn_off_bd_confirm_dialog_message">Siz uni istalgan vaqtda TalkBack sozlamalari orqali yoqishingiz mumkin</string>
  <string name="bd_turn_off_bd_confirm_dialog_positive_button">Oʻchirish</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_title">Ayrim buyruqlar ishlamaydi</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_message">Matn kirayotganda yoki tahrirlayotganda navigatsiya, brayl sozlamalari uchun buyruqlar va ayrim TalkBack funksiyalari ishlamaydi.\n\nBu buyruqlardan foydalanish uchun oldin klaviaturani yoping.</string>
  <string name="bd_caption_tutorial_dialog_title">Brayl ekranidagi tagyozuvlar</string>
  <string name="bd_caption_tutorial_dialog_message">Bu video uchun taglavhalarni koʻrsatish yoki berkitish uchun boʻsh joy va 1, 4, 7, 8 nuqtalarini bosing.\n\nMos multimedia uchun tagyozuvlarni avtomatik chiqarish uchun Sozlamalar orqali Brayl ekranida Tagyozuvlarni koʻrsatish sozlamasini yoqing.</string>
  <string name="bd_caption_tutorial_dialog_checkbox">Tagyozuvlar mavjud boʻlganda doim bu xabar chiqarilsin</string>
  <string name="bd_usb_connect_dialog_title">Brayl ekrani USB orqali ulandi</string>
  <string name="bd_usb_connect_dialog_message">%s batareyasi brayl ekraniga quvvatlamoqda.\n\nBluetoothga oʻtishni istasangiz, USB yoki USB habni uzing va TalkBack sozlamalari &gt; Brayl ekrani sahifasini oching.</string>
