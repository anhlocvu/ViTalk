  <string name="bd_enhanced_keymap_dialog_title">Passez au jeu de raccourcis clavier amélioré</string>
  <string name="bd_enhanced_keymap_dialog_message">Pour utiliser le mode navigation, passez du jeu de raccourcis clavier par défaut au jeu de raccourcis clavier amélioré. Cela mettra à jour certaines commandes de votre plage braille.</string>
  <string name="bd_enhanced_keymap_dialog_positive_button">Paramètres</string>
  <string name="bd_command_change_dialog_title">Certaines commandes ont été mises à jour</string>
  <string name="bd_command_change_dialog_message">Les commandes de plage braille suivantes ont été mises à jour dans cette version de TalkBack :\n\n• Élément précédent : appuyer sur les points 1 et 7\n\n• Élément suivant : appuyer sur les points 4 et 8\n\n• Contrôle de la lecture précédent : appuyer sur les points 2, 3, 7 et 8\n\n• Contrôle de la lecture suivante : appuyer sur les points 5, 6, 7 et 8</string>
  <string name="bd_preference_braille_contracted">Braille abrégé</string>
  <string name="bd_preference_braille_uncontracted">Braille intégral</string>
  <string name="bd_braille_grade_tips">Pour basculer rapidement entre le braille abrégé et le braille intégral avec une plage braille, appuyez sur la barre d\'espacement et sur les points 1, 2, 4 et 5.\n\nCette commande fonctionne si vous utilisez une langue qui emploie ces deux niveaux de braille.</string>
