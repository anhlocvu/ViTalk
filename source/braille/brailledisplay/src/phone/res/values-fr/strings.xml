  <string name="bd_bt_connect_fail_dialog_message">Assurez-vous que la plage braille est activée et à proximité.\n\nSi la connexion échoue toujours, appuyez deux fois sur \"En savoir plus\" pour découvrir d\'autres suggestions de dépannage.</string>
