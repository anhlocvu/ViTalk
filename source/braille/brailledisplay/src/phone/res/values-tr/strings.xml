  <string name="bd_command_change_dialog_title">Bazı komutlar güncellendi</string>
  <string name="bd_command_change_dialog_message">Bu TalkBack sürümünde güncellenen Braille ekran komutları:\n\n• Önceki öğe: 1, 7. noktalara basın\n\n• Sonraki öğe: 4, 8. noktalara basın\n\n• Önceki okuma kontrolü: 2, 3, 7, 8. noktalara basın\n\n• Sonraki okuma kontrolü: 5, 6, 7, 8. noktalara basın</string>
