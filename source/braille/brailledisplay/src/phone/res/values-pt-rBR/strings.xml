  <string name="bd_braille_elements_btn">• btn representa \"botão\"</string>
  <string name="bd_braille_elements_lnk">• lnk representa \"link\"</string>
  <string name="bd_braille_elements_drbtn">• drbtn representa um botão de menu suspenso</string>
  <string name="bd_braille_elements_clickable">• ⠿⠄ representa um elemento que pode ser ativado</string>
  <string name="bd_braille_elements_longClickable">• ⠿⠤ representa um elemento que você pode tocar e pressionar</string>
  <string name="bd_braille_elements_edt">• edt representa um campo de texto editável</string>
  <string name="bd_braille_elements_mln">• mln representa um campo de texto com várias linhas</string>
  <string name="bd_braille_elements_checked">• () ou (x) representa uma caixa de seleção ou um botão de opção</string>
  <string name="bd_braille_elements_checked_content_description">Parênteses ou x entre parênteses representam uma caixa de seleção ou um botão de opção</string>
  <string name="bd_braille_elements_sel">• sel representa um elemento selecionado</string>
  <string name="bd_braille_elements_gra">• gra representa uma imagem</string>
  <string name="bd_braille_elements_hdg">• hdg representa o título</string>
  <string name="bd_braille_elements_h1_to_h6">• h%1$s to h%2$s representa \"título %1$s a título %2$s\"</string>
  <string name="bd_braille_elements_expanded">• - representa \"aberto\"</string>
  <string name="bd_braille_elements_expanded_content_description">O sinal de menos significa que o conteúdo está aberto</string>
  <string name="bd_braille_elements_collapsed">• + representa \"fechado\"</string>
  <string name="bd_braille_elements_new_line">• ⠫⠇ representa uma nova linha</string>
  <string name="bd_braille_elements_in_progress">• ⠣⠿⠜ representa o carregamento</string>
  <string name="bd_braille_elements_lst">• lst representa uma lista</string>
  <string name="bd_braille_elements_chk">• chk representa uma caixa de seleção</string>
  <string name="bd_braille_elements_rbtn">• rbtn representa um botão de opção</string>
  <string name="bd_braille_elements_vlnk">• vlnk representa um link acessado</string>
  <string name="bd_braille_elements_tbl">• tbl representa uma tabela</string>
  <string name="bd_braille_elements_grd">• grd representa uma grade</string>
  <string name="bd_braille_elements_row">• [r1] representa a linha 1</string>
  <string name="bd_braille_elements_column">• [c1] representa a coluna 1</string>
  <string name="bd_braille_elements_row_column_count">• [grd 2r 1c] representa uma tabela com 2 linhas e 1 coluna</string>
  <string name="bd_braille_elements_row_column_and_row_column_count">• [r1 c2] [grd 5r 6c] é a posição atual na linha 1 e coluna 2, em uma tabela com 5 linhas e 6 colunas</string>
  <string name="bd_preference_key_auto_scroll_title">Rolagem automática</string>
