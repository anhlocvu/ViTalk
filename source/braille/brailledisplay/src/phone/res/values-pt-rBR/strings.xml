  <string name="bd_command_change_dialog_title">Alguns comandos foram atualizados</string>
  <string name="bd_command_change_dialog_message">Estes comandos da linha braille foram atualizados nesta versão do TalkBack:\n\n• Item anterior: pressione os pontos 1 e 7\n\n• Próximo item: pressione os pontos 4 e 8\n\n• Controle de leitura anterior: pressione os pontos 2, 3, 7 e 8\n\n• Próximo controle de leitura: pressione os pontos 5, 6, 7 e 8</string>
  <string name="bd_preference_braille_contracted">Braille abreviado</string>
  <string name="bd_preference_braille_uncontracted">Braille integral</string>
  <string name="bd_braille_grade_tips">Para alternar rapidamente o braille abreviado com o integral usando uma linha braille, pressione a barra de espaço e os pontos 1, 2, 4 e 5.\n\nEsse comando funciona caso você esteja usando um idioma com os dois graus.</string>
