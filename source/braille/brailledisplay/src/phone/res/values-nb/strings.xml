  <string name="bd_command_change_dialog_title">Noen kommandoer er oppdatert</string>
  <string name="bd_command_change_dialog_message">Disse leselistkommandoene er oppdatert i denne TalkBack-versjonen:\n\n• Forrige element: Trykk på punktene 1 og 7\n\n• Neste element: Trykk på punktene 4 og 8\n\n• Forrige lesekontroll: Trykk på punktene 2, 3, 7 og 8\n\n• Neste lesekontroll: Trykk på punktene 5, 6, 7 og 8</string>
  <string name="bd_preference_braille_contracted">Forkortet punktskrift</string>
  <string name="bd_preference_braille_uncontracted">Uforkortet punktskrift</string>
  <string name="bd_braille_grade_tips">For å bytte raskt mellom forkortet og uforkortet ved hjelp av en leselist, trykk på mellomrom og punkt 1, 2, 4 og 5.\n\nDenne kommandoen fungerer hvis du bruker et språk med begge punktskriftgradene.</string>
