  <string name="bd_turn_off_bd_confirm_dialog_positive_button">Izslēgt</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_title">Dažas komandas nav pieejamas.</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_message">Rakstīšanas vai rediģēšanas laikā nav pieejamas navigācijas komandas, Braila raksta iestatījumi un dažas TalkBack funkcijas.\n\nLai izmantotu šīs komandas, aizveriet tastatūru.</string>
  <string name="bd_caption_tutorial_dialog_title">Subtitri Braila displejā</string>
  <string name="bd_caption_tutorial_dialog_message">Lai rādītu vai paslēptu šī video subtitrus, nospiediet atstarpi un 1., 4., 7. un 8. punktu.\n\nLai automātiski rādītu subtitrus atbalstītam multivides saturam, iestatījumos ieslēdziet “Rādīt subtitrus Braila displejā”.</string>
  <string name="bd_caption_tutorial_dialog_checkbox">Vienmēr attēlot šo ziņojumu, kad ir pieejami subtitri</string>
  <string name="bd_usb_connect_dialog_title">Braila displejs ir savienots ar USB pieslēgvietu</string>
  <string name="bd_usb_connect_dialog_message">Braila displeja uzlādei tiek izmantots jūsu ierīces (%s) akumulators.\n\nJa nepieciešams izveidot Bluetooth savienojumu, atvienojiet USB vai USB centrmezglu un atveriet TalkBack iestatījumus &gt; Braila displejs.</string>
  <string name="bd_device">tālruņa</string>
  <string name="bd_battery_low_dialog_title">Zems %s akumulatora uzlādes līmenis</string>
  <string name="bd_battery_low_dialog_message">Braila displeja uzlādei tiek izmantots jūsu ierīces (%s) akumulators.\n\nLai taupītu akumulatora enerģiju, veiciet tālāk norādītās darbības.\n\n
    1. Atveriet Braila displeja iestatījumus.\n
    2. Atvienojiet Braila displeju no USB pieslēgvietas.\n
    3. Izveidojiet savienojumu ar Braila displeju, izmantojot Bluetooth.</string>
