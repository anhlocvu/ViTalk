  <string name="bd_enhanced_keymap_dialog_title">Passer au mappage du clavier amélioré pour utiliser le mode Parcourir</string>
  <string name="bd_enhanced_keymap_dialog_message">Pour utiliser le mode Parcourir, vous devrez passer du mappage du clavier par défaut au mappage du clavier amélioré. Cette modification mettra à jour certaines de vos commandes d\'afficheur braille</string>
