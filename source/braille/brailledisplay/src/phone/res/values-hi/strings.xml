  <string name="bd_commands_bindings_category_text_editing_summary">कर्सर मूव करके टेक्स्ट मिटाया जा सकता है</string>
  <string name="bd_commands_bindings_category_web_navigation_title">वेब नेविगेशन</string>
  <string name="bd_commands_bindings_category_web_navigation_summary">हेडिंग जैसे वेब कॉन्टेंट में नेविगेट करने के लिए शॉर्टकट</string>
  <string name="bd_preference_key_braille_elements_title">ब्रेल एलिमेंट</string>
  <string name="bd_preference_key_braille_elements_summary">जानें कि स्क्रीन पर दिखने वाले एलिमेंट, आपके ब्रेल डिसप्ले पर कैसे दिखते हैं</string>
  <string name="bd_braille_elements_instructions">आपकी स्क्रीन पर दिखने वाले एलिमेंट के लिए, ब्रेल डिसप्ले पर इन प्रतीकों का इस्तेमाल किया जाता है</string>
  <string name="bd_braille_elements_category_interacting_with_screen">स्क्रीन इंटरैक्शन से जुड़े कंट्रोल</string>
  <string name="bd_braille_elements_category_reading">टेक्स्ट पढ़ने से जुड़े कंट्रोल</string>
  <string name="bd_braille_elements_category_tables">टेबल</string>
  <string name="bd_braille_elements_btn">• btn से बटन का पता चलता है</string>
  <string name="bd_braille_elements_lnk">• lnk से लिंक का पता चलता है</string>
  <string name="bd_braille_elements_drbtn">• drbtn से ड्रॉपडाउन बटन का पता चलता है</string>
  <string name="bd_braille_elements_clickable">• ⠿⠄ से पता चलता है कि एलिमेंट को चालू किया जा सकता है</string>
  <string name="bd_braille_elements_longClickable">• ⠿⠤ से पता चलता है कि एलिमेंट को दबाकर रखा जा सकता है</string>
  <string name="bd_braille_elements_edt">• edt से पता चलता है कि टेक्स्ट फ़ील्ड में बदलाव किया जा सकता है</string>
  <string name="bd_braille_elements_mln">• mln से पता चलता है कि टेक्स्ट फ़ील्ड में एक से ज़्यादा लाइनें हैं</string>
  <string name="bd_braille_elements_checked">• () या (x) से चेकबॉक्स या रेडियो बटन का पता चलता है</string>
  <string name="bd_braille_elements_checked_content_description">ब्रैकेट या उसके अंदर x से, चेकबॉक्स या रेडियो बटन का पता चलता है</string>
  <string name="bd_braille_elements_sel">• sel से किसी चुने गए एलिमेंट का पता चलता है</string>
  <string name="bd_braille_elements_gra">• gra से ग्राफ़िक का पता चलता है</string>
  <string name="bd_braille_elements_hdg">• hdg से हेडिंग का पता चलता है</string>
  <string name="bd_braille_elements_h1_to_h6">• h%1$s से h%2$s तक की वैल्यू से, हेडिंग %1$s से हेडिंग %2$s तक का पता चलता है</string>
  <string name="bd_braille_elements_expanded">• - से पता चलता है कि एलिमेंट को बड़ा किया हुआ है</string>
  <string name="bd_braille_elements_expanded_content_description">माइनस साइन से पता चलता है कि कॉन्टेंट को बड़ा किया गया है</string>
  <string name="bd_braille_elements_collapsed">• + से पता चलता है कि एलिमेंट छोटा किया हुआ है</string>
  <string name="bd_braille_elements_new_line">• ⠫⠇ से नई लाइन का पता चलता है</string>
  <string name="bd_braille_elements_in_progress">• ⠣⠿⠜ से लोडिंग की प्रोसेस का पता चलता है</string>
  <string name="bd_braille_elements_lst">• lst से सूची का पता चलता है</string>
  <string name="bd_braille_elements_chk">• chk से चेकबॉक्स का पता चलता है</string>
  <string name="bd_braille_elements_rbtn">• rbtn से रेडियो बटन का पता चलता है</string>
  <string name="bd_braille_elements_vlnk">• vlnk से, खोले गए लिंक का पता चलता है</string>
  <string name="bd_braille_elements_tbl">• tbl से टेबल का पता चलता है</string>
  <string name="bd_braille_elements_grd">• grd से ग्रिड का पता चलता है</string>
  <string name="bd_braille_elements_row">• [r1] से पहली लाइन का पता चलता है</string>
  <string name="bd_braille_elements_column">• [c1] से पहले कॉलम का पता चलता है</string>
  <string name="bd_braille_elements_row_column_count">• [grd 2r 1c] से पता चलता है कि टेबल में दो लाइनें और एक कॉलम है</string>
  <string name="bd_braille_elements_row_column_and_row_column_count">• [r1 c2] [grd 5r 6c], यानी पांच लाइनों और छह कॉलम वाली टेबल में कर्सर पहली लाइन और दूसरे कॉलम पर है</string>
  <string name="bd_preference_key_auto_scroll_title">अपने-आप स्क्रोल होने की सुविधा</string>
  <string name="bd_preference_key_auto_scroll_summary">इससे ब्रेल डिसप्ले, तय की गई स्पीड के मुताबिक कॉन्टेंट को अपने-आप स्क्रोल करता है</string>
  <string name="bd_auto_scroll_instructions">ब्रेल डिसप्ले, तय स्पीड के मुताबिक कॉन्टेंट ऑटो-स्क्रोल करता है. इससे आगे का टेक्स्ट पढ़ने के लिए, बटन नहीं दबाना पड़ता. ऑटो-स्क्रोल चालू या बंद करने के लिए, स्पेस और बिंदु 1, 2, 4, 5, 6 दबाएं</string>
