  <string name="bd_cmd_subcategory_web_navigation_description">‏بااستفاده از دستور برای وارد شدن به حالت مرور، می‌توانید صفحات وب را به‌سرعت پیمایش کنید، سپس میان‌برهای حرفی یا عددی زیر را تایپ کنید\n\nاین میان‌برها را می‌توان بدون وارد شدن به حالت مرور نیز استفاده کرد، اما باید نقطه ۸ را به دستورات «بعدی» اضافه کنید</string>
  <string name="bd_cmd_subcategory_title_web_navigation">پیمایش جدول</string>
  <string name="bd_turn_off_bd_confirm_dialog_title">تنظیم نمایشگر بریل خاموش شود؟</string>
  <string name="bd_turn_off_bd_confirm_dialog_message">‏هروقت بخواهید می‌توانید این ویژگی را در تنظیمات TalkBack دوباره روشن کنید</string>
  <string name="bd_turn_off_bd_confirm_dialog_positive_button">خاموش شود</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_title">برخی‌از فرمان‌ها دردسترس نیست</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_message">‏درحین تایپ یا ویرایش کردن، فرمان‌های مربوط به پیمایش، تنظیمات بریل، و برخی‌از ویژگی‌های TalkBack دردسترس نیست.\n\nبرای استفاده از این فرمان‌ها، ابتدا صفحه‌کلید را ببندید.</string>
  <string name="bd_caption_tutorial_dialog_title">زیرنویس ناشنوایان در نمایشگر بریل</string>
  <string name="bd_caption_tutorial_dialog_message">‏برای نمایش دادن یا پنهان کردن زیرنویس ناشنوایان برای این ویدیو، فاصله و نقطه‌های ۱، ۴، ۷، ۸ را فشار دهید.\n\nبرای نمایش خودکار زیرنویس ناشنوایان برای رسانه‌های پشتیبانی‌شده، در «تنظیمات» گزینه «نمایش زیرنویس ناشنوایان در نمایشگر بریل» را روشن کنید.</string>
  <string name="bd_caption_tutorial_dialog_checkbox">همیشه وقتی زیرنویس ناشنوایان دردسترس است این پیام نشان داده شود</string>
  <string name="bd_usb_connect_dialog_title">‏نمایشگر بریل به USB متصل است</string>
  <string name="bd_usb_connect_dialog_message">‏باتری %s درحال شارژ کردن نمایشگر بریل است.\n\nاگر می‌خواهید از بلوتوث استفاده کنید، USB یا هاب USB را جدا کنید و به «تنظیمات TalkBack &gt; نمایشگر بریل» بروید.</string>
