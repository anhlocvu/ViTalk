  <string name="bd_turn_off_bd_confirm_dialog_positive_button">כיבוי</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_title">חלק מהפקודות לא זמינות</string>
  <string name="bd_notify_navigation_commands_unavailable_dialog_message">‏הפקודות לניווט, הגדרות הברייל וחלק מהתכונות של TalkBack לא זמינות בזמן הקלדה או עריכה.\n\nכדי להשתמש בפקודות האלה, יש לסגור קודם את המקלדת.</string>
  <string name="bd_caption_tutorial_dialog_title">כתוביות בצג הברייל</string>
  <string name="bd_caption_tutorial_dialog_message">‏כדי להפעיל או להשבית את הכתוביות בסרטון הזה, מקישים על מקש הרווח ועל הנקודות 1, 4, 7 ו-8.\n\nכדי שכתוביות תמיד יופעלו בסוגי מדיה שנתמכים, מפעילים את \"הפעלת כתוביות בצג הברייל\" בהגדרות.</string>
  <string name="bd_caption_tutorial_dialog_checkbox">ההודעה הזו מוצגת בכל פעם שיש כתוביות</string>
  <string name="bd_usb_connect_dialog_title">‏צג הברייל מחובר ל-USB</string>
  <string name="bd_usb_connect_dialog_message">‏הסוללה של %s טוענת את צג הברייל.\n\nאם צריך לעבור ל-Bluetooth, יש לנתק את ה-USB או את מפצל ה-USB ולעבור להגדרות של TalkBack &gt; \'צג ברייל\'.</string>
