    <!--
        Template for a row in a dialog containing information on a URL. The dialog_text is the
        hyperlinked text visible to the user before the dialog is opened, and dialog_url is the URL
        pathway. This string should not be used if dialog_text equals dialog_url. The text will be
        truncated if the text exceeds more than one line on the dialog.
    -->
    <string name="url_dialog_table">%1$s (%2$s)</string>

