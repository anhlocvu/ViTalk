    <string name="template_viewpager_index_count">Trang %1$d trên %2$d</string>
    <!--
        Source: A shorter utterance template for announcing the visible page inside a view pager.
        This is used if the view pager's current page has a content description.
        Description: This is spoken to the user. [CHAR LIMIT=NONE]
    -->
    <!-- TODO: This template is used by both ScrollFeedbackManager and Compositor, clean up dependency if we move this string. -->
