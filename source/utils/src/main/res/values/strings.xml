<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!-- To aid tooling, any string-containing xml file in this project should have a filename beginning with "strings" -->
<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">

    <!--
      Source: String spoken when a user as selected some characters in a password
      field, indicating the start and end point of the selection cursor. The word "characters" in
      this string means letters, numbers, or other symbols, NOT a person.
      Description: This is spoken to the user. [CHAR_LIMIT=NONE]
     -->
    <string name="template_password_selected">Ký tự từ %1$d đến %2$d</string>
    <!--
      Source: String spoken when a user has moved the text cursor inside a password field and the
      actual characters in the field are unknown. The word "character" in this string means a
      letter, number, or other symbol, NOT a person.
      Description: This is spoken to the user. [CHAR_LIMIT=NONE]
     -->
    <string name="template_password_traversed">Ký tự %1$d</string>

    <!-- Window title used for announcing untitled window. -->
    <string name="untitled_window">không có tiêu đề</string>

    <!--
    Source: An utterance template for announcing the shorten text feedback.
    Description: This is spoken to the user. [CHAR LIMIT=NONE]
    -->
    <string name="template_shorten_text">%1$d ký tự từ: %2$s đến %3$s</string>
    <!--
          Source: An utterance template for announcing copy of text (during edit).
          Description: This is spoken to the user. [CHAR LIMIT=NONE]
        -->
    <string name="template_text_copied">đã sao chép, %1$s</string>
    <!--
      Source: An utterance template for announcing a single upper-case (capital) letter.
      Description: This is spoken to the user. May not be translatable for some languages. [CHAR LIMIT=NONE]

      TODO: This string was moved to compositor's resource. We can remove it later.
    -->
    <string name="template_capital_letter">chữ hoa %1$s</string>
    <!-- Replacement string used when collapsing multiple repeated characters which is spoken to the user.  For example, in the case where we're about to speak 10 equal signs, we use this string to format the phrase "10 equal sign" rather than speaking "equal sign equal sign equal sign..." -->
