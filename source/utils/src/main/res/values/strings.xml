    <string name="template_scroll_from_count">Hiển thị mục %1$d/%2$d.</string>
    <!--
        Source: An utterance template for announcing the visible page inside a view pager.
        This is used if the view pager's current page does not have a content description.
        Description: This is spoken to the user. [CHAR LIMIT=NONE]
