<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbarStyle="outsideOverlay"
    android:theme="@style/A11yAlertDialogCustomViewTheme"
    android:gravity="top"
    android:orientation="vertical"
    android:clipChildren="true">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="@dimen/keyboard_shortcuts_dialog_search_bar_height"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:background="@drawable/keyboard_shortcuts_search_background"
      android:layout_marginTop="16dp"
      android:layout_marginBottom="8dp"
      android:layout_marginStart="24dp"
      android:layout_marginEnd="24dp"
      android:showDividers="beginning|middle|end"
      android:divider="@drawable/search_keyboard_commands_spacer">
    <ImageView
        android:layout_width="@dimen/keyboard_shortcuts_dialog_icon_size"
        android:layout_height="@dimen/keyboard_shortcuts_dialog_icon_size"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_search_black_24"
        android:tint="?attr/colorOnSurface"
        android:focusable="false"
        android:background="@null" />
    <EditText
        android:id="@+id/keyword_edit"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_gravity="center"
        android:hint="@string/keyboard_shortcuts_dialog_search_hint"
        android:inputType="text"
        android:singleLine="true"
        android:imeOptions="actionSearch"
        app:fontFamily="@string/accessibility_font"
        android:textSize="@dimen/kayboard_shortcuts_dialog_command_title_text_size"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textColorHint="?attr/colorOnSurfaceVariant"
        android:background="@null" />
    <ImageButton
        android:id="@+id/clear_button"
        android:layout_width="@dimen/keyboard_shortcuts_dialog_icon_size"
        android:layout_height="@dimen/keyboard_shortcuts_dialog_icon_size"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_clear_circle"
        android:tint="?attr/colorOnSurface"
        android:contentDescription="@string/searchview_clear_text_content_description"
        android:visibility="gone"
        android:background="@null" />
  </LinearLayout>

  <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/recycler_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content" />

  <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/no_results_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:text="@string/keyboard_shortcuts_no_results"
      app:fontFamily="@string/accessibility_font"
      android:textSize="@dimen/kayboard_shortcuts_dialog_category_title_text_size"
      android:textColor="?attr/colorOnSurfaceVariant"
      android:visibility="gone"
      android:focusable="true"
      android:focusableInTouchMode="true"
      />

  <View
      android:layout_width="match_parent"
      android:layout_height="1px"
      android:layout_gravity="bottom"
      android:background="?attr/colorOutlineVariant" />

</LinearLayout>