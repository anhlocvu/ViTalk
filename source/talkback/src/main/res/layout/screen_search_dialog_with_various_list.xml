<?xml version="1.0" encoding="utf-8"?>
<com.google.android.accessibility.talkback.actor.search.SearchScreenOverlayLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_background"
    android:contentDescription="@string/title_screen_search"
    android:orientation="vertical">
  <include layout="@layout/screen_search_toolbar_content" />
  <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/divider_color"
      android:focusable="false" />
  <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/search_result"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_gravity="end"
      android:contentDescription="@string/label_screen_search_result" />
</com.google.android.accessibility.talkback.actor.search.SearchScreenOverlayLayout>
