<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingHorizontal="24dp">

  <LinearLayout
      android:id="@+id/category_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:visibility="gone">
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_gravity="bottom"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="?attr/colorOutlineVariant"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/category_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textAlignment="viewStart"
        app:fontFamily="@string/accessibility_font"
        android:textSize="@dimen/kayboard_shortcuts_dialog_category_title_text_size"
        android:textColor="?attr/colorOnSurface"/>
  </LinearLayout>

  <LinearLayout
      android:id="@+id/keyboard_shortcut_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/keyboard_shortcut_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:textAlignment="viewStart"
        app:fontFamily="@string/accessibility_font"
        android:textSize="@dimen/kayboard_shortcuts_dialog_command_title_text_size"
        android:textColor="?attr/colorOnSurface"/>
   <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/keyboard_shortcut_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:textAlignment="viewStart"
        app:fontFamily="@string/accessibility_font"
        android:textSize="@dimen/kayboard_shortcuts_dialog_category_title_text_size"
        android:textColor="?attr/colorOnSurfaceVariant"/>
  </LinearLayout>

</LinearLayout>
