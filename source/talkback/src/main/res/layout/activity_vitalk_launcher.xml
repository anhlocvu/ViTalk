<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/vitalk_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="36dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ViTalk"
                android:textColor="@color/vitalk_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:contentDescription="ViTalk" />

            <TextView
                android:id="@+id/tv_slogan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trình đọc màn hình thân thiện với người Việt"
                android:textColor="@color/vitalk_text_secondary"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phiên bản 1.0"
                android:textColor="@color/vitalk_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/vitalk_divider"
            android:layout_marginBottom="24dp" />

        <!-- Button 1: Accessibility Status -->
        <LinearLayout
            android:id="@+id/btn_a11y_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/vitalk_card_bg"
            android:padding="18dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRẠNG THÁI DỊCH VỤ"
                android:textColor="@color/vitalk_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_a11y_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạng thái: Đang kiểm tra..."
                android:textColor="@color/vitalk_text_primary"
                android:textSize="15sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhấn để mở Cài đặt Trợ năng hệ thống"
                android:textColor="@color/vitalk_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Button 3: ViTalk Settings -->
        <LinearLayout
            android:id="@+id/btn_advanced_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/vitalk_card_bg"
            android:padding="18dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CÀI ĐẶT VÀ THIẾT LẬP"
                android:textColor="@color/vitalk_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cài đặt cấu hình chính cho ViTalk"
                android:textColor="@color/vitalk_text_primary"
                android:textSize="15sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cử chỉ vuốt, phím tắt vật lý, âm thanh phản hồi, giọng đọc và chữ nổi Braille"
                android:textColor="@color/vitalk_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Button 4: About -->
        <LinearLayout
            android:id="@+id/btn_about"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/vitalk_card_bg"
            android:padding="18dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIỚI THIỆU"
                android:textColor="@color/vitalk_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin ứng dụng và nhà phát triển"
                android:textColor="@color/vitalk_text_primary"
                android:textSize="15sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
