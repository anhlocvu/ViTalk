<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/training_padding_top"
    android:background="@color/training_tab_background_color"
    android:orientation="vertical">

  <com.google.android.material.tabs.TabLayout
      android:id="@+id/training_tabs"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:tabTextColor="@color/training_text_color" />

  <androidx.viewpager2.widget.ViewPager2
      android:id="@+id/training_tab_pager"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"/>

</LinearLayout>