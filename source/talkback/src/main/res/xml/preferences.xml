<?xml version="1.0" encoding="UTF-8"?>

<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

  <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
      android:key="@string/pref_survey_setting_entry_point_key"
      android:title="@string/survey_setting_title" />
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
      android:key="@string/pref_new_feature_in_talkback_entry_point_key"
      android:title="@string/new_feature_in_talkback_title" />
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_audio_key"
      android:title="@string/title_pref_category_audio">
    <com.google.android.accessibility.material.preference.AccessibilitySuiteListPreference
        android:defaultValue="@string/pref_speech_volume_default"
        android:dialogTitle="@string/title_pref_speech_volume"
        android:entries="@array/pref_speech_volume_entries"
        android:entryValues="@array/pref_speech_volume_values"
        android:key="@string/pref_speech_volume_key"
        android:summary="%s"
        android:title="@string/title_pref_speech_volume" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteListPreference
        android:defaultValue="@string/pref_speech_rate_default"
        android:dialogTitle="@string/title_pref_speech_rate"
        android:entries="@array/pref_speech_rate_entries"
        android:entryValues="@array/pref_speech_rate_values"
        android:key="@string/pref_speech_rate_key"
        android:summary="@string/summary_pref_speech_rate"
        android:title="@string/title_pref_speech_rate" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_tts_settings_key"
        android:title="@string/tts_preferences_title" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.VerbosityPrefFragment"
        android:key="@string/pref_verbosity_key"
        android:title="@string/pref_verbosity_title" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.AutomaticDescriptionsFragment"
        android:key="@string/pref_auto_image_captioning_key"
        android:summary="@string/summary_pref_auto_image_captioning"
        android:title="@string/title_pref_auto_image_captioning"/>
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.SoundAndVibrationFragment"
        android:key="@string/pref_sound_and_vibration_key"
        android:title="@string/title_pref_sound_and_vibration" />
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_visual_key"
      android:title="@string/title_pref_category_visual">
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.FocusIndicatorPrefFragment"
        android:key="@string/pref_category_manage_focus_indicator_key"
        android:title="@string/title_pref_category_manage_focus_indicator" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteSwitchPreference
        android:defaultValue="@bool/pref_tts_overlay_default"
        android:key="@string/pref_tts_overlay_key"
        android:title="@string/title_pref_tts_overlay"/>
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_controls_key"
      android:title="@string/title_pref_category_controls">
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.TalkBackGestureShortcutPreferenceFragment"
        android:key="@string/pref_category_manage_gestures_key"
        android:title="@string/title_pref_category_manage_gestures" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.CustomizeMenusFragment"
        android:key="@string/pref_manage_customize_menus_key"
        android:title="@string/title_pref_manage_customize_menus" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_category_manage_keyboard_shortcut_key"
        android:title="@string/title_pref_manage_keyboard_shortcuts"
        android:fragment="com.google.android.accessibility.talkback.preference.base.TalkBackKeyboardShortcutPreferenceFragment" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.GeminiSettingsFragment"
        android:key="@string/pref_gemini_settings_key"
        android:title="@string/title_pref_gemini_settings" />
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_typing_key"
      android:title="@string/title_pref_category_typing"
      app:allowDividerAbove="true" >
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.OnScreenKeyboardFragment"
        android:key="@string/pref_on_screen_keyboard_key"
        android:title="@string/title_pref_on_screen_keyboard" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_physical_keyboard_key"
        android:title="@string/title_pref_physical_keyboard" />
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_braille_key"
      android:title="@string/title_pref_category_braille">
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_brailleime_key"
        android:title="@string/title_pref_brailleime">
      <intent
          android:targetPackage="@string/app_id"
          android:targetClass="com.google.android.accessibility.brailleime.settings.BrailleImePreferencesActivity" />
    </com.google.android.accessibility.material.preference.AccessibilitySuitePreference>
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_brailledisplay_key"
        android:title="@string/title_pref_brailledisplay">
      <intent
          android:targetPackage="@string/app_id"
          android:targetClass="com.google.android.accessibility.braille.brailledisplay.settings.BrailleDisplaySettingsActivity" />
    </com.google.android.accessibility.material.preference.AccessibilitySuitePreference>
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_advanced_key"
      android:title="@string/title_pref_category_advanced">
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:fragment="com.google.android.accessibility.talkback.preference.base.AdvancedSettingFragment"
        android:key="@string/pref_advanced_settings_key"
        android:title="@string/title_pref_advanced_settings" />
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
  <com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory
      android:key="@string/pref_category_tutorial_and_help_key"
      android:title="@string/title_pref_category_tutorial_and_help">
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_tutorial_and_help_key"
        android:title="@string/title_pref_category_tutorial" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_help_and_feedback_key"
        android:title="@string/title_pref_help_and_feedback" />
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_gup_key"
        android:summary="@string/subtitle_pref_gup"
        android:title="@string/title_pref_gup" />
  </com.google.android.accessibility.material.preference.AccessibilitySuitePreferenceCategory>
</PreferenceScreen>
