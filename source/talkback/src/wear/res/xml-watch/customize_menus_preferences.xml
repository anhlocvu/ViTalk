<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:key="@string/pref_manage_customize_menus_key">
    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_category_manage_context_menu_key"
        android:summary="@string/pref_category_context_menu_summary"
        android:title="@string/title_pref_category_context_menu"
        android:fragment="com.google.android.accessibility.talkback.preference.base.ContextMenuFragment"
        app:splitSummary="true" />

    <com.google.android.accessibility.material.preference.AccessibilitySuitePreference
        android:key="@string/pref_category_manage_selector_menu_key"
        android:summary="@string/pref_category_selector_menu_summary"
        android:title="@string/title_pref_category_selector_menu"
        android:fragment="com.google.android.accessibility.talkback.preference.base.SelectorMenuFragment"
        app:splitSummary="true" />
</PreferenceScreen>