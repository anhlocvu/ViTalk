<?xml version="1.0" encoding="UTF-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:key="@string/pref_category_navigation_options_menu_key">
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_characters_default"
        android:key="@string/pref_show_navigation_menu_characters_setting_key"
        android:summary="@string/summary_characters"
        android:title="@string/granularity_character"
        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_words_default"
        android:key="@string/pref_show_navigation_menu_words_setting_key"
        android:summary="@string/summary_words"
        android:title="@string/granularity_word"
        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_lines_default"
        android:key="@string/pref_show_navigation_menu_lines_setting_key"
        android:summary="@string/summary_lines"
        android:title="@string/granularity_line"
        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_paragraphs_default"
        android:key="@string/pref_show_navigation_menu_paragraphs_setting_key"
        android:summary="@string/summary_paragraphs"
        android:title="@string/granularity_paragraph"
