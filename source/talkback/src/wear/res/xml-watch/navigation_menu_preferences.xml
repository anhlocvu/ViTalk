        android:defaultValue="@bool/pref_show_navigation_menu_window_default"
        android:key="@string/pref_show_navigation_menu_window_setting_key"
        android:summary="@string/summary_windows"
        android:title="@string/granularity_window"
        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_container_default"
        android:key="@string/pref_show_navigation_menu_container_setting_key"
        android:summary="@string/summary_containers"
        android:title="@string/granularity_container"
        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_granularity_default"
        android:key="@string/pref_show_navigation_menu_granularity_default_setting_key"
