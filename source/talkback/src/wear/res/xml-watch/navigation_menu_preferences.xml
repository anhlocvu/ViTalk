        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_controls_default"
        android:key="@string/pref_show_navigation_menu_controls_setting_key"
        android:summary="@string/summary_controls"
        android:title="@string/granularity_web_control"
        app:splitSummary="true" />
    <com.google.android.accessibility.material.preference.AccessibilitySuiteCheckBoxPreference
        android:defaultValue="@bool/pref_show_navigation_menu_links_default"
        android:key="@string/pref_show_navigation_menu_links_setting_key"
        android:summary="@string/summary_links"
